{
  "name": "@darshan/nextjs",
  "version": "0.1.0",
  "description": "Next.js SDK for DarshanDB \u2014 Server Components, App Router, Pages Router, and Middleware",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./provider": {
      "import": {
        "types": "./dist/provider.d.ts",
        "default": "./dist/provider.js"
      },
      "require": {
        "types": "./dist/provider.d.cts",
        "default": "./dist/provider.cjs"
      }
    },
    "./pages": {
      "import": {
        "types": "./dist/pages.d.ts",
        "default": "./dist/pages.js"
      },
      "require": {
        "types": "./dist/pages.d.cts",
        "default": "./dist/pages.cjs"
      }
    },
    "./middleware": {
      "import": {
        "types": "./dist/middleware.d.ts",
        "default": "./dist/middleware.js"
      },
      "require": {
        "types": "./dist/middleware.d.cts",
        "default": "./dist/middleware.cjs"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      },
      "require": {
        "types": "./dist/api.d.cts",
        "default": "./dist/api.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@darshan/client": "*",
    "@darshan/react": "*"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "@types/node": "^22.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darshjme/darshandb",
    "directory": "packages/nextjs"
  },
  "keywords": [
    "darshandb",
    "nextjs",
    "react",
    "server-components",
    "app-router",
    "database",
    "sdk",
    "realtime",
    "sync"
  ],
  "author": "Darsh Joshi",
  "homepage": "https://github.com/darshjme/darshandb/tree/main/packages/nextjs#readme",
  "bugs": {
    "url": "https://github.com/darshjme/darshandb/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}