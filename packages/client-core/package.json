{
  "name": "@darshjdb/client",
  "version": "0.4.0",
  "description": "Framework-agnostic TypeScript client SDK for DarshJDB",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2",
    "idb": "^8.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "@types/node": "^22.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darshjme/darshjdb",
    "directory": "packages/client-core"
  },
  "keywords": [
    "darshjdb",
    "database",
    "client",
    "sdk",
    "realtime",
    "sync",
    "offline"
  ],
  "author": "Darsh Joshi",
  "homepage": "https://github.com/darshjme/darshjdb/tree/main/packages/client-core#readme",
  "bugs": {
    "url": "https://github.com/darshjme/darshjdb/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}