{
  "name": "@darshjdb/react",
  "version": "0.4.0",
  "description": "React bindings for DarshJDB \u2014 hooks, provider, and real-time primitives",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@darshjdb/client": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "jsdom": "^29.0.1",
    "react": "^18.3.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "@types/node": "^22.0.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darshjme/darshjdb",
    "directory": "packages/react"
  },
  "keywords": [
    "darshjdb",
    "react",
    "hooks",
    "realtime",
    "database",
    "sync",
    "offline"
  ],
  "author": "Darsh Joshi",
  "homepage": "https://github.com/darshjme/darshjdb/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/darshjme/darshjdb/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}