{
    "name": "darshjdb/darshjdb-php",
    "description": "Official PHP SDK for DarshJDB — real-time database with auth, storage, and server-side functions.",
    "type": "library",
    "license": "MIT",
    "keywords": ["darshjdb", "database", "realtime", "sdk", "laravel"],
    "homepage": "https://github.com/darshjdb/darshjdb-php",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Darshjdb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Darshjdb\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Darshjdb\\Laravel\\ServiceProvider"
            ],
            "aliases": {
                "Darshjdb": "Darshjdb\\Laravel\\Facade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
